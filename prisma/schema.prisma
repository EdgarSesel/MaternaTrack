generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProviderRole {
  NURSE
  MIDWIFE
  OBGYN
  DIETITIAN
  THERAPIST
  ADMIN
}

enum PatientStatus {
  PRECONCEPTION
  PREGNANT
  POSTPARTUM
  INACTIVE
}

enum RiskLevel {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

enum TaskStatus {
  PENDING
  COMPLETED
  OVERDUE
  SNOOZED
  NOT_APPLICABLE
}

enum MessageSenderType {
  PROVIDER
  PATIENT
  SYSTEM
}

model Provider {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String
  name            String
  role            ProviderRole
  lastLoginAt     DateTime?
  onboardedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  patients        Patient[]
  appointments    Appointment[]
  visitNotes      VisitNote[]
  handoffsFrom    Handoff[]       @relation("HandoffFrom")
  handoffsTo      Handoff[]       @relation("HandoffTo")
  patientAccesses PatientAccess[]
}

model Patient {
  id                  String        @id @default(cuid())
  providerId          String
  provider            Provider      @relation(fields: [providerId], references: [id])
  firstName           String
  lastName            String
  dateOfBirth         DateTime
  gestationalAgeWeeks Int?
  dueDate             DateTime?
  enrollmentDate      DateTime      @default(now())
  status              PatientStatus @default(PREGNANT)
  insuranceType       String?
  riskScore           Int           @default(0)
  riskLevel           RiskLevel     @default(LOW)
  riskFactors         Json          @default("[]")
  socialDeterminants  Json          @default("{}")
  medicalHistory      Json          @default("{}")
  lastContactAt       DateTime?
  lastContactChannel  String?
  aiRiskSummary       String?
  aiRiskSummaryAt     DateTime?
  deletedAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  vitals           Vital[]
  screenings       Screening[]
  carePlans        CarePlan[]
  careTasks        CareTask[]
  messages         Message[]
  timelineEvents   TimelineEvent[]
  riskScoreHistory RiskScoreHistory[]
  appointments     Appointment[]
  portalUser       PatientUser?
  visitNotes       VisitNote[]
  handoffs         Handoff[]
  babies           Baby[]
  patientAccesses  PatientAccess[]

  @@index([providerId])
  @@index([riskScore])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
}

model PatientUser {
  id           String    @id @default(cuid())
  patientId    String    @unique
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  email        String    @unique
  passwordHash String
  lastLoginAt  DateTime?
  consentedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

model Vital {
  id         String   @id @default(cuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type       String
  value      Json
  recordedAt DateTime
  source     String   @default("manual")
  createdAt  DateTime @default(now())

  @@index([patientId, recordedAt])
  @@index([patientId, type])
}

model Screening {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type           String
  score          Int?
  riskResult     String?
  responses      Json     @default("{}")
  administeredAt DateTime
  administeredBy String?
  createdAt      DateTime @default(now())

  @@index([patientId, type])
}

model CarePlan {
  id           String    @id @default(cuid())
  patientId    String
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  protocolType String
  status       String    @default("active")
  activatedAt  DateTime  @default(now())
  completedAt  DateTime?
  config       Json      @default("{}")
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tasks        CareTask[]

  @@index([patientId])
  @@index([status])
}

model CareTask {
  id           String     @id @default(cuid())
  carePlanId   String?
  carePlan     CarePlan?  @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  patientId    String
  patient      Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  dueDate      DateTime
  status       TaskStatus @default(PENDING)
  priority     String     @default("normal")
  completedAt  DateTime?
  completedBy  String?
  snoozeUntil  DateTime?
  snoozeReason String?
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([patientId, status])
  @@index([status, dueDate])
}

model Message {
  id          String            @id @default(cuid())
  patientId   String
  patient     Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  senderType  MessageSenderType
  senderId    String?
  content     String
  messageType String            @default("text")
  readAt      DateTime?
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())

  @@index([patientId, createdAt])
  @@index([readAt])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  eventType   String
  title       String
  description String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([patientId, createdAt])
}

model RiskScoreHistory {
  id           String    @id @default(cuid())
  patientId    String
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  score        Int
  level        RiskLevel
  factors      Json
  calculatedAt DateTime  @default(now())

  @@index([patientId, calculatedAt])
}

model Appointment {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  providerId      String
  provider        Provider @relation(fields: [providerId], references: [id])
  type            String
  scheduledAt     DateTime
  duration        Int      @default(30)
  status          String   @default("scheduled")
  notes           String?
  // Recurrence support
  seriesId        String?  // links all appointments in a recurring series
  recurrenceRule  String?  // "weekly", "biweekly", "monthly" (only set on series root)
  recurrenceEnd   DateTime? // when the series ends
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  visitNotes      VisitNote[]

  @@index([patientId, scheduledAt])
  @@index([providerId, scheduledAt])
  @@index([seriesId])
}

model VisitNote {
  id            String    @id @default(cuid())
  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  providerId    String
  provider      Provider  @relation(fields: [providerId], references: [id])
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  subjective    String    @default("") // What the patient reports
  objective     String    @default("") // Measurable findings (vitals, exam)
  assessment    String    @default("") // Clinical interpretation
  plan          String    @default("") // Actions and follow-up
  signedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([patientId, createdAt])
  @@index([providerId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorType  String   // "provider" | "patient" | "system"
  action     String   // "patient.view", "task.complete", "message.send"
  resource   String   // "Patient", "CareTask", "Message"
  resourceId String?
  metadata   Json     @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([resource, resourceId])
  @@index([action, createdAt])
}

model Notification {
  id            String    @id @default(cuid())
  recipientId   String    // providerId or patientUserId
  recipientType String    // "provider" | "patient"
  type          String    // "new_message" | "risk_escalation" | "appointment_reminder" | "care_gap" | "task_overdue"
  title         String
  body          String?
  patientId     String?   // context link
  resourceId    String?   // e.g. appointmentId, messageId
  readAt        DateTime?
  emailSentAt   DateTime?
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now())

  @@index([recipientId, readAt])
  @@index([recipientId, createdAt])
}

model Handoff {
  id             String    @id @default(cuid())
  patientId      String
  patient        Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fromProviderId String
  fromProvider   Provider  @relation("HandoffFrom", fields: [fromProviderId], references: [id])
  toProviderId   String
  toProvider     Provider  @relation("HandoffTo", fields: [toProviderId], references: [id])
  summary        String
  openConcerns   String?
  pendingTasks   Json      @default("[]")
  aiSummary      String?
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([toProviderId, acceptedAt])
  @@index([patientId])
}

model Baby {
  id                   String    @id @default(cuid())
  patientId            String
  patient              Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  firstName            String?
  dateOfBirth          DateTime?
  birthWeightGrams     Int?
  gestationalAgeAtBirth Int?
  apgarScore1Min       Int?
  apgarScore5Min       Int?
  deliveryType         String?   // vaginal, cesarean, vbac
  nicuAdmission        Boolean   @default(false)
  nicuDays             Int?
  feedingType          String?   // breast, formula, mixed
  dischargedAt         DateTime?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  neonatalVitals       NeonatalVital[]

  @@index([patientId])
}

model PatientAccess {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  role        String   // "secondary", "consulting", "covering"
  grantedAt   DateTime @default(now())
  grantedById String?  // provider who created the access

  @@unique([patientId, providerId])
  @@index([providerId])
  @@index([patientId])
}

model NeonatalVital {
  id         String   @id @default(cuid())
  babyId     String
  baby       Baby     @relation(fields: [babyId], references: [id], onDelete: Cascade)
  type       String   // weight, length, head_circumference, bilirubin, temperature
  value      Json     // { value: number, unit: string }
  recordedAt DateTime
  createdAt  DateTime @default(now())

  @@index([babyId, recordedAt])
}
